# Dev environment — copy to .env and edit as needed.
# Every setting here matches the code's default, so an empty .env also works.

# --- Django core ---
DJANGO_DEBUG=1
DJANGO_SECRET_KEY=django-insecure-development-key-please-change-in-production
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,testserver
# DJANGO_CSRF_TRUSTED_ORIGINS=
# DJANGO_BEHIND_PROXY=0
# DJANGO_SECURE_SSL_REDIRECT=0

# --- Database (Postgres) ---
DB_NAME=regulatory_db
DB_USER=regulatory_user
DB_PASSWORD=password
DB_HOST=localhost
DB_PORT=5432

# --- CORS (frontend dev server) ---
DJANGO_CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# --- Mistral LLM ---
USE_LOCAL_MISTRAL=false
LOCAL_MISTRAL_URL=http://localhost:11434/v1
MISTRAL_API_KEY=
